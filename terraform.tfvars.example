# CloudEngine Labs - Terraform Variable Values
# Copy this file to terraform.tfvars and update the values

aws_region    = "us-east-1"
instance_type = "t2.micro"

# Docker Hub image
docker_image  = "santhosh1024/flask-cloudengine:latest"

# Optional: Your AWS key pair name for SSH access
# key_name    = "your-key-pair-name"
